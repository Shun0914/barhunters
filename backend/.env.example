# カンマ区切りでブラウザからのオリジンを許可（本番はフロントの URL を追加）
ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

DATABASE_URL=sqlite:///./local.db

# ── デモ認証（Issue #16）────────────────────────────────────────────
DEMO_PASSWORD=demo
JWT_SECRET=dev-change-me-in-production
JWT_EXPIRE_MINUTES=480
SESSION_COOKIE_NAME=barhunters_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
# ログイン後の役割切替（X-Dev-User-Id）。デモ Azure のみ true 推奨
ALLOW_DEV_AUTH_HEADER=true

# 開発用ヘッダ切替の既定ユーザー（任意）
# DEV_DEFAULT_USER_ID=11111111-1111-1111-1111-111111111111
